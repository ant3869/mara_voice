# Copy this file to .env and fill in the blanks.
# .env is ignored by git. Do not commit API keys.

# Required only when routing prompts to OpenClaw.
MARA_OPENCLAW_API_KEY=

# OpenClaw on the Dell rig.
MARA_OPENCLAW_BASE_URL=http://192.168.0.65:8645/v1
MARA_OPENCLAW_MODEL=gemini 3.1 pro
MARA_OPENCLAW_TIMEOUT=600
MARA_OPENCLAW_VOICE_STYLE=A clear adult male speaking voice with a steady lower register, calm conversational pace, natural articulation, and no humming, sighing, singing, or nonverbal sounds
MARA_OPENCLAW_VOICE_REFERENCE_PATH=models/openclaw_voice_reference.wav
MARA_OPENCLAW_VOICE_REFERENCE_TEXT=OpenClaw is online, steady, direct, and ready to answer clearly.

# Default route: hermes or openclaw.
MARA_ACTIVE_AGENT=hermes

# Hermes over SSH.
MARA_SSH_TARGET=ant@192.168.0.65
MARA_HERMES_COMMAND=~/.local/bin/hermes
MARA_SSH_TIMEOUT=0
MARA_SSH_CONNECT_TIMEOUT=5

# Voicebox/TTS local pipeline. Leave blank values blank to use defaults.
MARA_CAPTURE_DIR=
MARA_AUDIO_DEVICE=
# Use the GPU. "cuda" forces it (falls back to CPU with a loud warning if unavailable);
# "auto" also prefers the GPU when present. CPU inference is very slow.
MARA_TTS_DEVICE=cuda
MARA_TTS_TIMEOUT=300
# Diffusion steps. Lower = faster generation, slightly lower quality. 6 is the
# default; try 4 for max speed, 8-10 for best quality.
MARA_TTS_INFERENCE_TIMESTEPS=6
MARA_STATUS_INTERVAL=10
MARA_SPOKEN_REPLY_CHAR_LIMIT=900
MARA_ASYNC_AGENT_REPLIES=1
# Acknowledgement: 0 = instant random preset phrase (recommended); 1 = agent-generated.
# Agent-generated acks need their own agent round trip, so they arrive about when the
# real answer does and don't fill dead air - leave this 0 unless you have a reason.
MARA_ASYNC_ACK_AGENT=0
# Wait this long for the real answer before speaking an acknowledgement. If the
# answer arrives first, no acknowledgement is spoken (avoids double replies on quick
# prompts). 0 always speaks one immediately.
MARA_ASYNC_ACK_GRACE_SECONDS=5
# Single fallback phrase used when no preset phrases are set and as the last resort.
MARA_ASYNC_ACK_TEXT=Yeah, let me dig into that real quick.
# Optional preset phrases chosen at random when MARA_ASYNC_ACK_AGENT=0. Multi-line
# lists are easiest to manage from the GUI; leave blank to use MARA_ASYNC_ACK_TEXT.
MARA_ASYNC_ACK_PHRASES=
MARA_ASYNC_FOLLOWUP_ENABLED=1
MARA_ASYNC_FOLLOWUP_INITIAL_DELAY_SECONDS=3
MARA_ASYNC_FOLLOWUP_POLL_SECONDS=8
MARA_ASYNC_FOLLOWUP_MAX_ATTEMPTS=60
MARA_VOICE_INBOX_PATH=
MARA_VOICE_INBOX_POLL_SECONDS=5
MARA_AGENT_SESSION_ID=voice-session
MARA_HERMES_SESSION_ID=voice-session-hermes
MARA_OPENCLAW_SESSION_ID=voice-session-openclaw
MARA_AGENT_SESSION_HISTORY_PATH=
MARA_AGENT_SESSION_HISTORY_MESSAGES=20
MARA_AGENT_SESSION_PERSISTENCE=1

# Playback latency controls.
MARA_TTS_STREAMING=1
MARA_TTS_CHUNK_CHAR_LIMIT=450
MARA_TTS_STREAM_CHUNK_CHAR_LIMIT=1200
# Streaming prebuffer. With dynamic prebuffering on, SECONDS is the floor and
# MAX_SECONDS the ceiling; the cushion grows automatically when generation is slow.
MARA_TTS_STREAM_PREBUFFER_SECONDS=0.5
MARA_TTS_STREAM_PREBUFFER_DYNAMIC=1
MARA_TTS_STREAM_PREBUFFER_MAX_SECONDS=4
MARA_PROCESS_EXISTING_SECONDS=600
